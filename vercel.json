{
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/api/blog/:slug" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/sessions", "destination": "/sessions.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/library", "destination": "/library.html" },
    { "source": "/vaultlibrary", "destination": "/vaultlibrary.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/legal", "destination": "/legal.html" },
    { "source": "/post", "destination": "/post.html" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "redirects": [
    { "source": "/blog/index.html", "destination": "/", "permanent": true },
    { "source": "/blog/sessions.html", "destination": "/sessions", "permanent": true },
    { "source": "/blog/about.html", "destination": "/about", "permanent": true },
    { "source": "/blog/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/blog/faq.html", "destination": "/faq", "permanent": true },
    { "source": "/blog/library.html", "destination": "/library", "permanent": true },
    { "source": "/blog/register.html", "destination": "/register", "permanent": true },
    { "source": "/blog/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/blog/legal.html", "destination": "/legal", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/sessions.html", "destination": "/sessions", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/faq.html", "destination": "/faq", "permanent": true },
    { "source": "/library.html", "destination": "/library", "permanent": true },
    { "source": "/vaultlibrary.html", "destination": "/vaultlibrary", "permanent": true },
    { "source": "/register.html", "destination": "/register", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/legal.html", "destination": "/legal", "permanent": true },
    { "source": "/post.html", "destination": "/post", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/workspace",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/workspace.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/vaultlibrary",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/vaultlibrary.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    },
    {
      "source": "/post",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow, noarchive, max-image-preview:large" }
      ]
    },
    {
      "source": "/post.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow, noarchive, max-image-preview:large" }
      ]
    },
    {
      "source": "/posts/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow, noarchive, noimageindex" }
      ]
    }
  ]
}
